<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ca</string>
		<string>es</string>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>app.ping.ios.refresh</string>
	</array>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCalendarsUsageDescription</key>
	<string>Ping uses your calendar to suggest when to leave for upcoming commutes.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Ping uses your location to estimate how long it takes to walk to your origin station.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>TMB_APP_ID_BACKUP</key>
	<string>$(TMB_APP_ID_BACKUP)</string>
	<key>TMB_APP_ID_PRIMARY</key>
	<string>$(TMB_APP_ID_PRIMARY)</string>
	<key>TMB_APP_KEY_BACKUP</key>
	<string>$(TMB_APP_KEY_BACKUP)</string>
	<key>TMB_APP_KEY_PRIMARY</key>
	<string>$(TMB_APP_KEY_PRIMARY)</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>Ping sends leave-now reminders for upcoming trips.</string>
	<key>UIApplicationSceneManifest</key>
	<dict/>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
